# ========================================
# 🔧 CONFIGURACIÓN DEL SERVIDOR
# ========================================
NODE_ENV=development
PORT=4201

# ========================================
# 🗄️  BASE DE DATOS (MongoDB)
# ========================================
MONGO_URI=mongodb://127.0.0.1:27017/terpel
MONGO_USER=admin
MONGO_PASSWORD=your_secure_password_here

# ========================================
# 🔐 AUTENTICACIÓN (JWT)
# ========================================
# Cambiar en PRODUCCIÓN por una clave segura de 32+ caracteres
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=1h

# ========================================
# 📧 EMAIL (Futuro: notificaciones)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ========================================
# 🔑 API KEYS (Servicios externos)
# ========================================
GOOGLE_API_KEY=your_google_api_key
STRIPE_API_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_public_key

# ========================================
# 🌐 CORS (Dominios permitidos)
# ========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# 📊 LOGGING (Nivel de logs)
# ========================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ========================================
# 🚀 PRODUCCIÓN
# ========================================
SENTRY_DSN=your_sentry_dsn_for_error_monitoring
