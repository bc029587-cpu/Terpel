{
  "info": {
    "name": "Terpel API Collection",
    "description": "Colección completa de endpoints para testing",
    "version": "2.0.0"
  },
  "requests": [
    {
      "name": "🔓 Health Check",
      "method": "GET",
      "url": "{{baseUrl}}/health",
      "headers": {},
      "description": "Verificar que el servidor está activo"
    },
    {
      "name": "🔑 Auth - Login",
      "method": "POST",
      "url": "{{baseUrl}}/api/auth/login",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "email": "admin@terpel.com",
        "password": "123456"
      },
      "description": "Obtener token JWT"
    },
    {
      "name": "🔑 Auth - Register",
      "method": "POST",
      "url": "{{baseUrl}}/api/auth/register",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "email": "newuser@ejemplo.com",
        "password": "123456",
        "name": "Nuevo Usuario"
      },
      "description": "Registrar nuevo usuario"
    },
    {
      "name": "🔑 Auth - Me",
      "method": "GET",
      "url": "{{baseUrl}}/api/auth/me",
      "headers": {
        "Authorization": "Bearer {{token}}"
      },
      "description": "Obtener información del usuario actual"
    },
    {
      "name": "👥 Users - Get All",
      "method": "GET",
      "url": "{{baseUrl}}/api/users",
      "headers": {
        "Authorization": "Bearer {{token}}"
      },
      "description": "Listar todos los usuarios"
    },
    {
      "name": "👥 Users - Get by ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/users/:id",
      "headers": {
        "Authorization": "Bearer {{token}}"
      },
      "description": "Obtener usuario por ID"
    },
    {
      "name": "👥 Users - Update",
      "method": "PUT",
      "url": "{{baseUrl}}/api/users/:id",
      "headers": {
        "Authorization": "Bearer {{token}}",
        "Content-Type": "application/json"
      },
      "body": {
        "name": "Nombre Actualizado",
        "email": "newemail@ejemplo.com"
      },
      "description": "Actualizar usuario"
    },
    {
      "name": "👥 Users - Delete",
      "method": "DELETE",
      "url": "{{baseUrl}}/api/users/:id",
      "headers": {
        "Authorization": "Bearer {{token}}"
      },
      "description": "Eliminar usuario (soft delete)"
    },
    {
      "name": "👥 Users - Change Password",
      "method": "POST",
      "url": "{{baseUrl}}/api/users/change-password",
      "headers": {
        "Authorization": "Bearer {{token}}",
        "Content-Type": "application/json"
      },
      "body": {
        "currentPassword": "123456",
        "newPassword": "nuevacontraseña123"
      },
      "description": "Cambiar contraseña del usuario actual"
    },
    {
      "name": "📦 Service Orders - Get All",
      "method": "GET",
      "url": "{{baseUrl}}/api/service-orders",
      "headers": {
        "Authorization": "Bearer {{token}}"
      },
      "description": "Listar todas las órdenes de servicio"
    },
    {
      "name": "📦 Service Orders - Create",
      "method": "POST",
      "url": "{{baseUrl}}/api/service-orders",
      "headers": {
        "Authorization": "Bearer {{token}}",
        "Content-Type": "application/json"
      },
      "body": {
        "title": "Orden de Servicio #001",
        "description": "Mantenimiento de estación",
        "status": "PENDING"
      },
      "description": "Crear nueva orden de servicio"
    },
    {
      "name": "📦 Service Orders - Get by ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/service-orders/:id",
      "headers": {
        "Authorization": "Bearer {{token}}"
      },
      "description": "Obtener orden de servicio por ID"
    },
    {
      "name": "📦 Service Orders - Update Status",
      "method": "PUT",
      "url": "{{baseUrl}}/api/service-orders/:id/status",
      "headers": {
        "Authorization": "Bearer {{token}}",
        "Content-Type": "application/json"
      },
      "body": {
        "status": "IN_PROGRESS"
      },
      "description": "Actualizar estado de orden de servicio"
    },
    {
      "name": "📦 Service Orders - Update",
      "method": "PUT",
      "url": "{{baseUrl}}/api/service-orders/:id",
      "headers": {
        "Authorization": "Bearer {{token}}",
        "Content-Type": "application/json"
      },
      "body": {
        "title": "Nuevo Título",
        "description": "Nueva descripción",
        "status": "PENDING"
      },
      "description": "Actualizar orden de servicio completa"
    },
    {
      "name": "📦 Service Orders - Delete",
      "method": "DELETE",
      "url": "{{baseUrl}}/api/service-orders/:id",
      "headers": {
        "Authorization": "Bearer {{token}}"
      },
      "description": "Eliminar orden de servicio"
    }
  ],
  "variables": {
    "baseUrl": "http://localhost:4201",
    "token": "paste_your_token_here_after_login"
  }
}
